  "clients": [
    {
      "clientId": "laboratorio-api",
      "name": "API do Laboratorio",
      "enabled": true,
        "publicClient": false,
        "clientAuthenticatorType": "client-secret",
        "secret": "laboratorio-api-secret",
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "protocolMappers": [
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "usermodel.clientRoleMapping.clientId": "laboratorio-api"
          }
        }
      ],
      "authorizationServicesEnabled": true,
      "authorizationSettings": {
        "allowRemoteResourceManagement": true,
        "policyEnforcementMode": "ENFORCING",
        "resources": [
          {
            "name": "documentos",
            "displayName": "Documentos",
            "uris": [
              "/documentos",
              "/documentos/*"
            ],
            "scopes": [
              {
                "name": "ler"
              },
              {
                "name": "criar"
              },
              {
                "name": "editar"
              },
              {
                "name": "aprovar"
              }
            ]
          }
        ],
        "scopes": [
          {
            "name": "ler"
          },
          {
            "name": "criar"
          },
          {
            "name": "editar"
          },
          {
            "name": "aprovar"
          }
        ],
        "policies": [
          {
            "name": "Somente leitores",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "roles": "[{\"id\":\"role-documentos-ler\",\"required\":true}]"
            }
          },
          {
            "name": "Somente editores",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "roles": "[{\"id\":\"role-documentos-editar\",\"required\":true}]"
            }
          },
          {
            "name": "Somente criadores",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "roles": "[{\"id\":\"role-documentos-criar\",\"required\":true}]"
            }
          },
          {
            "name": "Somente aprovadores",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "roles": "[{\"id\":\"role-documentos-aprovar\",\"required\":true}]"
            }
          },
          {
            "name": "Permissao para ler documentos",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"documentos\"]",
              "scopes": "[\"ler\"]",
              "applyPolicies": "[\"Somente leitores\"]"
            }
          },
          {
            "name": "Permissao para criar documentos",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"documentos\"]",
              "scopes": "[\"criar\"]",
              "applyPolicies": "[\"Somente criadores\"]"
            }
          },
          {
            "name": "Permissao para editar documentos",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"documentos\"]",
              "scopes": "[\"editar\"]",
              "applyPolicies": "[\"Somente editores\"]"
            }
          },
          {
            "name": "Permissao para aprovar documentos",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"documentos\"]",
              "scopes": "[\"aprovar\"]",
              "applyPolicies": "[\"Somente aprovadores\"]"
            }
          }
        ]
      }
    },
