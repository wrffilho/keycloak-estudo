  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var server       = pm.environment.get(\"keycloak_url\") || \"http://localhost:8080\";",
          "var realm        = pm.environment.get(\"realm\") || \"laboratorio-keycloak\";",
          "var grantType    = \"password\";",
          "var clientId     = pm.environment.get(\"client_id\") || \"laboratorio-api\";",
          "var clientSecret = pm.environment.get(\"client_secret\") || \"laboratorio-api-secret\";",
          "var username     = pm.request.headers.get(\"X-Usuario-Teste\") || pm.environment.get(\"usuario_teste\") || \"leitor\";",
          "var password     = pm.environment.get(\"senha_padrao\") || \"senha123\";",
          "",
          "pm.request.headers.remove(\"X-Usuario-Teste\");",
          "",
          "if (pm.request.auth && pm.request.auth.type === \"noauth\") {",
          "    return;",
          "}",
          "",
          "var tokenDaqueleUsuario = pm.environment.get(`token_${username}`);",
          "if (tokenDaqueleUsuario) {",
          "    pm.environment.set(\"token\", tokenDaqueleUsuario);",
          "    pm.request.headers.upsert({ key: \"Authorization\", value: `Bearer ${tokenDaqueleUsuario}` });",
          "    return;",
          "}",
          "",
          "var url = `${server}/realms/${realm}/protocol/openid-connect/token`;",
          "var data = `grant_type=${grantType}&client_id=${clientId}&username=${username}&password=${password}&client_secret=${clientSecret}`;",
          "",
          "pm.sendRequest({",
          "    url: url,",
          "    method: \"POST\",",
          "    header: { \"Content-Type\": \"application/x-www-form-urlencoded\" },",
          "    body: {",
          "        mode: \"raw\",",
          "        raw: data",
          "    }",
          "}, function(err, response) {",
          "    if (err) {",
          "        console.error(\"Erro ao obter token:\", err);",
          "        return;",
          "    }",
          "",
          "    var responseJson = response.json();",
          "    if (responseJson.access_token) {",
          "        var token = responseJson.access_token;",
          "        pm.environment.set(`token_${username}`, token);",
          "        pm.environment.set(\"token\", token);",
          "        pm.request.headers.upsert({ key: \"Authorization\", value: `Bearer ${token}` });",
          "    } else {",
          "        console.error(\"Erro na resposta do Keycloak:\", responseJson);",
          "    }",
          "});"
        ]
      }
    },
